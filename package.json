{
  "name": "mission-control",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-dev-ports.mjs",
    "dev": "pnpm --parallel --filter backend --filter frontend --filter @mission-control/mcp dev",
    "dev:app": "pnpm --parallel --filter backend --filter frontend dev",
    "dev:mcp": "pnpm --filter @mission-control/mcp dev",
    "dev:relay": "pnpm --filter @mission-control/agent-webhook-relay dev",
    "build": "pnpm --filter backend build && pnpm --filter frontend build && pnpm --filter @mission-control/mcp build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "tsx": "^4.19.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
