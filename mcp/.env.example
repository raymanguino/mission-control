# URL of the mission-control backend
BACKEND_URL=http://localhost:3001

# Same PIN/password as backend DASHBOARD_PASSWORD. MCP calls POST /api/auth/login
# and uses the returned JWT for all backend requests (same auth as the web UI).
DASHBOARD_PASSWORD=

# API key clients must send in the Authorization header: "Bearer <key>"
MCP_API_KEY=change-me-to-a-random-secret

PORT=3002
