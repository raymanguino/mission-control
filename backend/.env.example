DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DASHBOARD_PASSWORD=changeme
DASHBOARD_SECRET=change-me-to-a-long-random-secret
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=3001
# Logging (pino-roll with daily rotation, 14-day retention, gzip compression)
LOG_DIR=logs
LOG_FILE=backend.log
LOG_LEVEL=info
# Set to false to disable outbound role webhooks (project.* events to OpenClaw relay)
AGENT_WEBHOOKS_ENABLED=true
# Origin for POST /hooks/mc — role is inferred from the event field in the payload (e.g. https://your-tailscale-host or http://127.0.0.1:48123)
MC_WEBHOOK_BASE_URL=
# Bearer token for all outbound webhook POSTs (relay must accept this value via Authorization: Bearer)
MC_WEBHOOK_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_GENERAL_CHANNEL_ID=
# Optional: Discord channel snowflake for project success/failure posts (defaults to a guild channel named "general")
DISCORD_GENERAL_CHANNEL_ID=
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=mission-control@yourdomain.com